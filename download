<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>YT to MP3 — Convertidor Máxima Calidad</title>
  <meta name="description" content="Convierte videos de YouTube a MP3 en máxima calidad (320kbps) y descárgalos instantáneamente. Sin límites, sin marcas de agua." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="style.css" />
</head>
<body>
  <div class="bg-orbs">
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>
    <div class="orb orb-3"></div>
  </div>
  <canvas id="particles-canvas"></canvas>

  <div class="app-wrapper">
    <header class="header">
      <div class="logo">
        <div class="logo-icon">
          <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M12 22C17.5228 22 22 17.5228 22 12C22 6.47715 17.5228 2 12 2C6.47715 2 2 6.47715 2 12C2 17.5228 6.47715 22 12 22Z" stroke="url(#g1)" stroke-width="2"/>
            <path d="M8 12C8 9.79086 9.79086 8 12 8C14.2091 8 16 9.79086 16 12C16 14.2091 14.2091 16 12 16C9.79086 16 8 14.2091 8 12Z" fill="url(#g1)"/>
            <defs><linearGradient id="g1" x1="2" y1="2" x2="22" y2="22" gradientUnits="userSpaceOnUse"><stop stop-color="#a855f7"/><stop offset="1" stop-color="#3b82f6"/></linearGradient></defs>
          </svg>
        </div>
        <div class="logo-text">
          <span class="logo-title">YT<span class="accent">MP3</span></span>
          <span class="logo-sub">Máxima Calidad · 320kbps</span>
        </div>
      </div>
      <div class="quality-badge"><span class="badge-dot"></span>320kbps · Sin límites</div>
    </header>

    <main class="main-card">
      <div class="card-inner">
        <h1 class="card-title">Convierte YouTube a <span class="gradient-text">MP3</span></h1>
        <p class="card-desc">Pega el enlace del video y descarga el audio en la máxima calidad posible. Rápido, gratis y sin restricciones.</p>

        <div class="input-group" id="input-group">
          <div class="input-wrapper">
            <div class="input-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
            </div>
            <input type="url" id="youtube-url" placeholder="https://www.youtube.com/watch?v=..." autocomplete="off" spellcheck="false"/>
            <button class="paste-btn" id="paste-btn" title="Pegar URL">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
            </button>
          </div>
          <button class="convert-btn" id="convert-btn">
            <span class="btn-text">Buscar Video</span>
            <svg class="btn-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
          </button>
        </div>

        <!-- Video Preview -->
        <div class="video-preview" id="video-preview" style="display:none;">
          <div class="preview-thumbnail-wrapper">
            <img id="preview-thumbnail" src="" alt="Miniatura" />
            <div class="play-overlay"><svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg></div>
          </div>
          <div class="preview-info">
            <div class="preview-platform">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
              YouTube
            </div>
            <h2 id="preview-title" class="preview-title"></h2>
            <div class="preview-meta">
              <span id="preview-uploader" class="meta-item">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                <span></span>
              </span>
              <span id="preview-duration" class="meta-item">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                <span></span>
              </span>
              <span id="preview-views" class="meta-item">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                <span></span>
              </span>
            </div>
            <div class="quality-info">
              <div class="quality-chip"><svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>MP3 · 320kbps</div>
              <div class="quality-chip"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>Máxima Calidad</div>
            </div>
          </div>
        </div>

        <!-- Progress -->
        <div class="progress-section" id="progress-section" style="display:none;">
          <div class="progress-header">
            <span class="progress-label" id="progress-label">Iniciando...</span>
            <span class="progress-percent" id="progress-percent">0%</span>
          </div>
          <div class="progress-bar-wrapper">
            <div class="progress-bar" id="progress-bar"><div class="progress-glow"></div></div>
          </div>
          <div class="progress-steps">
            <div class="step" id="step-download"><div class="step-dot"></div><span>Descargando</span></div>
            <div class="step" id="step-convert"><div class="step-dot"></div><span>Convirtiendo</span></div>
            <div class="step" id="step-ready"><div class="step-dot"></div><span>¡Listo!</span></div>
          </div>
        </div>

        <!-- Download Ready -->
        <div class="download-ready" id="download-ready" style="display:none;">
          <div class="success-icon"><svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg></div>
          <div class="ready-text"><strong>¡Tu MP3 está listo!</strong><p>Calidad 320kbps · Descarga inmediata</p></div>
          <a class="download-btn" id="download-link" href="#" download>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            Descargar MP3
          </a>
          <button class="new-btn" id="new-btn"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/></svg>Convertir otro</button>
        </div>

        <!-- Error -->
        <div class="error-section" id="error-section" style="display:none;">
          <div class="error-icon"><svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg></div>
          <div class="error-content"><strong>Ocurrió un error</strong><p id="error-message"></p></div>
          <button class="retry-btn" id="retry-btn">Intentar de nuevo</button>
        </div>
      </div>
    </main>

    <section class="features">
      <div class="feature-card">
        <div class="feature-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg></div>
        <h3>320kbps</h3><p>Máxima calidad de audio posible</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M13 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z"/><polyline points="13 2 13 9 20 9"/></svg></div>
        <h3>Sin límites</h3><p>Descarga todos los videos que quieras</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg></div>
        <h3>Privado</h3><p>Proceso local, sin guardar datos</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg></div>
        <h3>Ultra rápido</h3><p>Conversión acelerada en servidor</p>
      </div>
    </section>

    <footer class="footer"><p>YT<strong>MP3</strong> · Uso personal · Máxima calidad garantizada</p></footer>
  </div>
  <script src="app.js"></script>
</body>
</html>
